---
import Layout from '../layouts/Layout.astro';
import { business } from '../business.config.js';

const serviceDetails = (business.services || []).map((s, i) => ({
  ...s,
  desc: "Professional service with attention to detail and guaranteed results. We use industry-leading equipment and proven methods to deliver exceptional outcomes every time.",
  bullets: ["Free estimate included", "Licensed & insured technicians", "Satisfaction guaranteed", "Flexible scheduling"]
}));
---

<Layout title={`Services | ${business.name}`}>

  <header class="site-header scrolled" id="site-header" style="background:var(--primary);">
    <div style="max-width:1200px; margin:0 auto; padding:0 24px; display:flex; align-items:center; justify-content:space-between; height:72px;">
      <a href="/" style="font-family:var(--font-heading); font-weight:900; font-size:1.3rem; color:var(--white); text-decoration:none; text-transform:uppercase;">{business.name}</a>
      <nav class="desktop-nav" style="display:flex; gap:32px;">
        <a href="/services" style="color:var(--accent); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Services</a>
        <a href="/gallery" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Gallery</a>
        <a href="/about" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">About</a>
        <a href="/contact" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Contact</a>
        {business.photoPageEnabled && <a href="/photo" style="color:var(--accent); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Photo Diagnosis</a>}
      </nav>
      <a href="#" data-quote-modal class="btn-primary quote-cta-btn" style="padding:10px 20px; font-size:0.8rem;">Get Free Quote</a>
      <button id="hamburger-btn" class="hamburger-btn" aria-label="Open navigation menu" aria-expanded="false">☰</button>
    </div>
  </header>

  <nav id="mobile-menu" class="mobile-nav" aria-hidden="true">
    <a href="/services">Services</a>
    <a href="/about">About</a>
    <a href="/gallery">Gallery</a>
    <a href="/contact">Contact</a>
    {business.photoPageEnabled && <a href="/photo">Photo Diagnosis</a>}
  </nav>

  <section style={`background:linear-gradient(rgba(0,0,0,0.75), rgba(24,34,64,0.97)), url('${business.heroImageUrl}') center/cover; padding:140px 24px 80px;`}>
    <div style="max-width:1200px; margin:0 auto; text-align:center;">
      <span class="section-label">Everything We Do</span>
      <h1 style="font-size:clamp(2.5rem, 5vw, 4rem); color:var(--white); margin-bottom:16px;">Our Services</h1>
      <p style="color:var(--text-light); font-size:1.1rem; max-width:560px; margin:0 auto 32px;">Professional, licensed, and fully insured. Every job done right the first time.</p>
      <a href="#" data-quote-modal class="btn-primary">Get a Free Quote Today</a>
    </div>
  </section>

  <div style="background:var(--accent); padding:14px 24px;">
    <div style="max-width:1200px; margin:0 auto; display:flex; justify-content:center; gap:40px; flex-wrap:wrap;">
      {(business.badges || []).map((badge) => (
        <div style="font-family:var(--font-heading); font-weight:700; font-size:0.85rem; color:#000; text-transform:uppercase;">✓ {badge}</div>
      ))}
    </div>
  </div>

  <section style="background:var(--primary); padding:80px 24px;">
    <div style="max-width:1200px; margin:0 auto; display:flex; flex-direction:column; gap:64px;">
      {serviceDetails.map((service, i) => (
        <div class="svc-row">
          <div class="svc-text" style={i % 2 === 1 ? 'order:2;' : 'order:1;'}>
            <div style="font-size:3rem; margin-bottom:16px;">{service.icon}</div>
            <h2 style="font-size:clamp(1.6rem, 3vw, 2.2rem); color:var(--white); margin-bottom:16px;">{service.name}</h2>
            <p style="color:var(--text-light); line-height:1.7; margin-bottom:24px;">{service.desc}</p>
            <ul style="display:flex; flex-direction:column; gap:10px; margin-bottom:28px; list-style:none; padding:0;">
              {service.bullets.map((b) => (
                <li style="display:flex; align-items:center; gap:10px; color:var(--text-light); font-size:0.95rem;">
                  <span style="color:var(--accent); font-weight:700; flex-shrink:0;">✓</span> {b}
                </li>
              ))}
            </ul>
            <a href="#" data-quote-modal class="btn-primary">Get a Free Quote</a>
          </div>
          <div class="svc-img" style={`background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; overflow:hidden; aspect-ratio:4/3; ${i % 2 === 1 ? 'order:1;' : 'order:2;'}`}>
            <img src={business.heroImageUrl} alt={service.name} style="width:100%; height:100%; object-fit:cover; opacity:0.7;" />
          </div>
        </div>
      ))}
    </div>
  </section>

  <section style="background:var(--accent); padding:64px 24px; text-align:center;">
    <div style="max-width:600px; margin:0 auto;">
      <h2 style="font-family:var(--font-heading); font-weight:900; font-size:2.5rem; text-transform:uppercase; color:#000; margin-bottom:16px;">Ready to Get Started?</h2>
      <p style="color:rgba(0,0,0,0.7); margin-bottom:32px;">Get your free estimate today. No pressure, no obligation.</p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="#" data-quote-modal style="background:#000; color:#fff; font-family:var(--font-heading); font-weight:700; text-transform:uppercase; padding:16px 32px; border-radius:5px; text-decoration:none;">Get Free Quote</a>
        <a href={`tel:${business.phone}`} style="background:transparent; color:#000; font-family:var(--font-heading); font-weight:700; text-transform:uppercase; padding:14px 30px; border-radius:5px; text-decoration:none; border:2px solid #000;">Call {business.phone}</a>
      </div>
    </div>
  </section>

  <footer style="background:#000; padding:32px 24px; text-align:center;">
    <div style="font-family:var(--font-heading); font-weight:900; color:var(--white); text-transform:uppercase; margin-bottom:8px;">{business.name}</div>
    <div style="font-size:0.8rem; color:var(--text-muted);">© 2025 {business.name}. All Rights Reserved. · <a href="/" style="color:var(--accent); text-decoration:none;">Home</a> · <a href="/contact" style="color:var(--accent); text-decoration:none;">Contact</a></div>
  </footer>

<style>
  .svc-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  @media (max-width: 768px) {
    .svc-row {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .svc-img {
      order: 1 !important;
    }
    .svc-text {
      order: 2 !important;
    }
  }
</style>

</Layout>
