---
import Layout from '../layouts/Layout.astro';
import { business } from '../business.config.js';
---

<Layout title={`About | ${business.name}`}>

  <header class="site-header scrolled" style="background:var(--primary);">
    <div style="max-width:1200px; margin:0 auto; padding:0 24px; display:flex; align-items:center; justify-content:space-between; height:72px;">
      <a href="/" style="font-family:var(--font-heading); font-weight:900; font-size:1.3rem; color:var(--white); text-decoration:none; text-transform:uppercase;">{business.name}</a>
      <nav class="desktop-nav" style="display:flex; gap:32px;">
        <a href="/services" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Services</a>
        <a href="/gallery" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Gallery</a>
        <a href="/about" style="color:var(--accent); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">About</a>
        <a href="/contact" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Contact</a>
        {business.photoPageEnabled && <a href="/photo" style="color:var(--accent); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Photo Diagnosis</a>}
      </nav>
      <a href="#" data-quote-modal class="btn-primary quote-cta-btn" style="padding:10px 20px; font-size:0.8rem;">Get Free Quote</a>
      <button id="hamburger-btn" class="hamburger-btn" aria-label="Open navigation menu" aria-expanded="false">☰</button>
    </div>
  </header>

  <nav id="mobile-menu" class="mobile-nav" aria-hidden="true">
    <a href="/services">Services</a>
    <a href="/about">About</a>
    <a href="/gallery">Gallery</a>
    <a href="/contact">Contact</a>
    {business.photoPageEnabled && <a href="/photo">Photo Diagnosis</a>}
  </nav>

  <section style={`background:linear-gradient(rgba(0,0,0,0.75), rgba(24,34,64,0.97)), url('${business.heroImageUrl}') center/cover; padding:140px 24px 80px;`}>
    <div style="max-width:1200px; margin:0 auto; text-align:center;">
      <span class="section-label">Our Story</span>
      <h1 style="font-size:clamp(2.5rem, 5vw, 4rem); color:var(--white); margin-bottom:16px;">About {business.name}</h1>
      <p style="color:var(--text-light); font-size:1.1rem; max-width:560px; margin:0 auto;">{business.subtagline}</p>
    </div>
  </section>

  <section style="background:var(--primary); padding:80px 24px;">
    <div style="max-width:1200px; margin:0 auto;" class="about-cols">
      <div style="border-radius:12px; overflow:hidden; aspect-ratio:4/3;">
        <img src={business.heroImageUrl} alt={business.name} style="width:100%; height:100%; object-fit:cover; opacity:0.85;" />
      </div>
      <div>
        <span class="section-label">Who We Are</span>
        <h2 style="font-size:clamp(1.8rem, 3vw, 2.5rem); color:var(--white); margin-bottom:20px;">Your Trusted Local Expert</h2>
        <p style="color:var(--text-light); line-height:1.8; margin-bottom:16px; font-size:1rem;">{business.description}</p>
        <p style="color:var(--text-muted); line-height:1.8; margin-bottom:32px; font-size:0.95rem;">
          We built this business on a simple principle: treat every customer's property like it's our own. That means showing up on time, doing the job right the first time, and standing behind our work.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:12px;">
          {(business.badges || []).map((badge) => (
            <div style="background:rgba(242,202,82,0.1); border:1px solid var(--accent); border-radius:5px; padding:8px 14px; font-family:var(--font-heading); font-size:0.75rem; font-weight:700; text-transform:uppercase; color:var(--accent);">{badge}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section style="background:#000; padding:80px 24px;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:48px;">
        <span class="section-label">By The Numbers</span>
        <h2 class="section-title" style="font-size:2.5rem;">Why Customers Choose Us</h2>
      </div>
      <div class="stats-grid">
        {[
          { number: "500+", label: "Jobs Completed" },
          { number: "5★", label: "Average Rating" },
          { number: "20+", label: "Years Experience" },
          { number: "100%", label: "Satisfaction Rate" },
        ].map((stat) => (
          <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:32px 20px;">
            <div style="font-family:var(--font-heading); font-weight:900; font-size:2.8rem; color:var(--accent); margin-bottom:8px;">{stat.number}</div>
            <div style="font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase; color:var(--white); letter-spacing:0.05em;">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--primary); padding:80px 24px;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:48px;">
        <span class="section-label">Hear It From Them</span>
        <h2 class="section-title" style="font-size:2.5rem;">Customer Reviews</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:24px;">
        {(business.reviews || []).map((review) => (
          <div style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:28px;">
            <div style="display:flex; gap:2px; margin-bottom:12px;">
              {[1,2,3,4,5].map(() => <span style="color:var(--accent);">★</span>)}
            </div>
            <p style="color:var(--text-light); line-height:1.6; font-size:0.95rem; margin-bottom:16px; font-style:italic;">"{review.text}"</p>
            <div style="font-family:var(--font-heading); font-weight:700; color:var(--white);">{review.name}</div>
            <div style="font-size:0.8rem; color:var(--text-muted);">{review.location}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--accent); padding:64px 24px; text-align:center;">
    <div style="max-width:600px; margin:0 auto;">
      <h2 style="font-family:var(--font-heading); font-weight:900; font-size:2.5rem; text-transform:uppercase; color:#000; margin-bottom:16px;">Let's Work Together</h2>
      <p style="color:rgba(0,0,0,0.7); margin-bottom:32px;">Get your free estimate today from a team you can trust.</p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="#" data-quote-modal style="background:#000; color:#fff; font-family:var(--font-heading); font-weight:700; text-transform:uppercase; padding:16px 32px; border-radius:5px; text-decoration:none;">Get Free Quote</a>
        <a href={`tel:${business.phone}`} style="background:transparent; color:#000; font-family:var(--font-heading); font-weight:700; text-transform:uppercase; padding:14px 30px; border-radius:5px; text-decoration:none; border:2px solid #000;">Call {business.phone}</a>
      </div>
    </div>
  </section>

  <footer style="background:#000; padding:32px 24px; text-align:center;">
    <div style="font-family:var(--font-heading); font-weight:900; color:var(--white); text-transform:uppercase; margin-bottom:8px;">{business.name}</div>
    <div style="font-size:0.8rem; color:var(--text-muted);">© 2025 {business.name}. All Rights Reserved. · <a href="/" style="color:var(--accent); text-decoration:none;">Home</a> · <a href="/contact" style="color:var(--accent); text-decoration:none;">Contact</a></div>
  </footer>


<style>
  .about-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    text-align: center;
  }
  @media (max-width: 768px) {
    .about-cols {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
</style>

</Layout>
