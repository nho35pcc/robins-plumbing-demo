---
import Layout from '../layouts/Layout.astro';
import { business } from '../business.config.js';
---

<Layout title={`Gallery | ${business.name}`}>

  <header class="site-header scrolled" style="background:var(--primary);">
    <div style="max-width:1200px; margin:0 auto; padding:0 24px; display:flex; align-items:center; justify-content:space-between; height:72px;">
      <a href="/" style="font-family:var(--font-heading); font-weight:900; font-size:1.3rem; color:var(--white); text-decoration:none; text-transform:uppercase;">{business.name}</a>
      <nav class="desktop-nav" style="display:flex; gap:32px;">
        <a href="/services" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Services</a>
        <a href="/gallery" style="color:var(--accent); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Gallery</a>
        <a href="/about" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">About</a>
        <a href="/contact" style="color:var(--white); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Contact</a>
        {business.photoPageEnabled && <a href="/photo" style="color:var(--accent); text-decoration:none; font-family:var(--font-heading); font-weight:700; font-size:0.85rem; text-transform:uppercase;">Photo Diagnosis</a>}
      </nav>
      <a href="#" data-quote-modal class="btn-primary quote-cta-btn" style="padding:10px 20px; font-size:0.8rem;">Get Free Quote</a>
      <button id="hamburger-btn" class="hamburger-btn" aria-label="Open navigation menu" aria-expanded="false">☰</button>
    </div>
  </header>

  <nav id="mobile-menu" class="mobile-nav" aria-hidden="true">
    <a href="/services">Services</a>
    <a href="/about">About</a>
    <a href="/gallery">Gallery</a>
    <a href="/contact">Contact</a>
    {business.photoPageEnabled && <a href="/photo">Photo Diagnosis</a>}
  </nav>

  <section style={`background:linear-gradient(rgba(0,0,0,0.75), rgba(24,34,64,0.97)), url('${business.heroImageUrl}') center/cover; padding:140px 24px 80px;`}>
    <div style="max-width:1200px; margin:0 auto; text-align:center;">
      <span class="section-label">Our Work</span>
      <h1 style="font-size:clamp(2.5rem, 5vw, 4rem); color:var(--white); margin-bottom:16px;">Project Gallery</h1>
      <p style="color:var(--text-light); font-size:1.1rem; max-width:560px; margin:0 auto;">Real results from real jobs. See the quality we deliver on every project.</p>
    </div>
  </section>

  <section style="background:#000; padding:80px 24px;">
    <div style="max-width:1200px; margin:0 auto;">

      <div style="display:flex; justify-content:center; gap:12px; margin-bottom:48px; flex-wrap:wrap;">
        {['All Work', ...business.services.slice(0,4).map(s => s.name)].map((filter, i) => (
          <button style={`font-family:var(--font-heading); font-weight:700; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.08em; padding:10px 20px; border-radius:5px; cursor:pointer; border:2px solid ${i === 0 ? 'var(--accent)' : 'rgba(255,255,255,0.2)'}; background:${i === 0 ? 'var(--accent)' : 'transparent'}; color:${i === 0 ? '#000' : 'var(--white)'};`}>
            {filter}
          </button>
        ))}
      </div>

      <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:16px;">
        {Array.from({length: 9}).map((_, i) => (
          <div style="border-radius:10px; overflow:hidden; aspect-ratio:4/3; position:relative; cursor:pointer;" class="gallery-item">
            <img src={business.heroImageUrl} alt={`Project ${i+1}`} style={`width:100%; height:100%; object-fit:cover; opacity:0.75; filter:hue-rotate(${i * 15}deg) brightness(${0.8 + (i % 3) * 0.1});`} />
            <div style="position:absolute; inset:0; background:rgba(0,0,0,0); display:flex; align-items:center; justify-content:center; transition:background 0.2s;" class="gallery-overlay">
              <div style="color:var(--white); font-family:var(--font-heading); font-weight:700; font-size:0.9rem; text-transform:uppercase; opacity:0; transition:opacity 0.2s;" class="gallery-label">
                {business.services[i % business.services.length]?.name}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div style="text-align:center; margin-top:48px;">
        <p style="color:var(--text-muted); margin-bottom:20px; font-size:0.95rem;">Like what you see? Let's talk about your project.</p>
        <a href="#" data-quote-modal class="btn-primary">Get a Free Quote</a>
      </div>
    </div>
  </section>

  <section style="background:var(--primary); padding:64px 24px;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="text-align:center; margin-bottom:40px;">
        <span class="section-label">Real Feedback</span>
        <h2 class="section-title" style="font-size:2rem;">What Customers Say</h2>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:24px;">
        {(business.reviews || []).map((review) => (
          <div style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:28px;">
            <div style="display:flex; gap:2px; margin-bottom:12px;">
              {[1,2,3,4,5].map(() => <span style="color:var(--accent);">★</span>)}
            </div>
            <p style="color:var(--text-light); line-height:1.6; font-size:0.95rem; margin-bottom:16px; font-style:italic;">"{review.text}"</p>
            <div style="font-family:var(--font-heading); font-weight:700; font-size:0.9rem; color:var(--white);">{review.name}</div>
            <div style="font-size:0.8rem; color:var(--text-muted);">{review.location}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <footer style="background:#000; padding:32px 24px; text-align:center;">
    <div style="font-family:var(--font-heading); font-weight:900; color:var(--white); text-transform:uppercase; margin-bottom:8px;">{business.name}</div>
    <div style="font-size:0.8rem; color:var(--text-muted);">© 2025 {business.name}. All Rights Reserved. · <a href="/" style="color:var(--accent); text-decoration:none;">Home</a> · <a href="/contact" style="color:var(--accent); text-decoration:none;">Contact</a></div>
  </footer>

</Layout>

<style>
  .gallery-item:hover .gallery-overlay { background: rgba(0,0,0,0.5) !important; }
  .gallery-item:hover .gallery-label { opacity: 1 !important; }
</style>
