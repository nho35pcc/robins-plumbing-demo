---
import { business } from "../business.config.js";
---

<section id="services" style="background:#0a0e1a;">
  <div class="container">
    <div style="text-align:center; margin-bottom:80px;">
      <h2 style="margin-bottom:10px;">OUR SERVICES</h2>
      <div style="width:80px; height:4px; background:#F2CA52; margin:0 auto;">
      </div>
    </div>

    <div
      style="display:grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap:30px;"
    >
      {
        business.services.map((s) => (
          <div style="background:#161f38; padding:60px 40px; border-radius:12px; border:1px solid rgba(255,255,255,0.05); text-align:center;">
            <div style="font-size:4rem; margin-bottom:25px;">{s.icon}</div>
            <h3 style="font-size:1.6rem; font-weight:900; margin-bottom:15px;">
              {s.name}
            </h3>
            <p style="opacity:0.6; line-height:1.7; margin-bottom:30px;">
              {s.desc}
            </p>
            <button
              class="btn-quote"
              style="padding:10px 20px !important; font-size:0.75rem !important;"
            >
              GET INSTANT PRICE
            </button>
          </div>
        ))
      }
    </div>
  </div>
</section>
