---
import { business } from "../business.config.js";
---

<section
  style="padding:100px 24px; background:#0d1428; border-top: 1px solid rgba(255,255,255,0.05);"
>
  <div style="max-width:1200px; margin:0 auto; text-align:center;">
    <h2 style="font-size:2.5rem; font-weight:900; margin-bottom:80px;">
      OUR 5-STEP PROCESS
    </h2>
    <div
      style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:40px;"
    >
      {
        business.process.map((p) => (
          <div style="position:relative;">
            <div style="width:60px; height:60px; background:var(--accent); color:var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 25px; font-weight:900; font-size:1.2rem; box-shadow: 0 0 20px rgba(242, 202, 82, 0.3);">
              {p.step}
            </div>
            <h4 style="margin-bottom:12px; font-weight:900;">{p.title}</h4>
            <p style="font-size:0.85rem; opacity:0.6; line-height:1.5;">
              {p.desc}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
