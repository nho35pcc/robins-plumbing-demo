---
import { business } from "../business.config.js";
---

<section
  style={`min-height:95vh; display:flex; align-items:center; padding: 130px 40px 80px; background: linear-gradient(rgba(10,14,26,0.8), rgba(10,14,26,0.8)), url(${business.heroImageUrl}); background-size:cover; background-position:center;`}
>
  <div
    style="max-width:1300px; margin:0 auto; width:100%; display:grid; grid-template-columns: 1fr 450px; gap:80px; align-items:center;"
  >
    <div>
      <span
        style="color:var(--accent); font-weight:900; letter-spacing:3px; text-transform:uppercase; font-size:0.85rem;"
        >{business.tagline}</span
      >
      <h1
        style="font-size: clamp(3rem, 6vw, 5rem); font-weight:900; line-height:0.85; margin: 20px 0 35px; text-transform:uppercase; letter-spacing:-2px;"
      >
        {business.name} — <br /><span style="color:var(--accent);"
          >The Washing Experts</span
        >
      </h1>
      <div
        style="display:flex; align-items:center; gap:25px; margin-bottom:45px; background:rgba(255,255,255,0.03); padding:15px 25px; border-radius:50px; width:fit-content; border:1px solid rgba(255,255,255,0.05);"
      >
        <div style="color:var(--accent); font-size:1.6rem; letter-spacing:2px;">
          ★★★★★
        </div>
        <div
          style="display:flex; gap:15px; border-left:1px solid rgba(255,255,255,0.2); padding-left:20px;"
        >
          {
            business.socialLinks.map((s) => (
              <img
                src={s.icon}
                style="height:28px; filter:brightness(0) invert(1);"
                alt={s.label}
              />
            ))
          }
        </div>
      </div>
      <button
        class="btn-quote"
        style="padding:25px 60px !important; font-size:1.1rem !important; border-radius:50px !important;"
        >Start My Estimate</button
      >
    </div>

    <div
      style="background: rgba(28, 38, 69, 0.9); padding:55px 45px; border-radius:12px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 40px 80px rgba(0,0,0,0.6); backdrop-filter: blur(20px);"
    >
      <div style="text-align:center; margin-bottom:35px;">
        <img
          src="/logo.png"
          style="height:55px; margin-bottom:15px;"
          alt="Logo"
        />
        <h2
          style="font-size:1.6rem; font-weight:900; color:white; text-transform:uppercase; letter-spacing:1px;"
        >
          Get A Free Quote
        </h2>
      </div>
      <form style="display:flex; flex-direction:column; gap:12px;">
        <input
          type="text"
          placeholder="Full Name *"
          style="padding:18px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:white; border-radius:4px; font-family:inherit;"
        />
        <input
          type="tel"
          placeholder="Phone Number *"
          style="padding:18px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:white; border-radius:4px; font-family:inherit;"
        />
        <textarea
          placeholder="Tell us about your project..."
          style="padding:18px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:white; border-radius:4px; height:100px; font-family:inherit; resize:none;"
        ></textarea>
        <button
          type="submit"
          class="btn-quote"
          style="width:100%; margin-top:10px; padding:20px !important;"
          >Send My Quote Request</button
        >
      </form>
    </div>
  </div>
</section>
