---
import { business } from "../business.config.js";
---

<section id="areas" style="padding: 100px 24px; background: #0a0e1a;">
  <div
    style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start;"
  >
    <div>
      <h2 style="font-size: 2.5rem; font-weight: 900; margin-bottom: 30px;">
        SERVICE AREAS
      </h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
        {
          business.serviceAreas.map((area) => (
            <div style="color: white; opacity: 0.7; font-size: 0.9rem;">
              📍 {area}
            </div>
          ))
        }
      </div>
    </div>
    <div
      style="height: 400px; background: #161f38; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.3);"
    >
      [ Google Map Placeholder for {business.city} ]
    </div>
  </div>
</section>
